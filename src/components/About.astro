---
import data from '../data/about.json';
const { texte_1, texte_2, citation, citation_auteur } = data;
---
<section id="association" class="py-16 sm:py-24 px-5 sm:px-8 bg-stone-50 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.035] pointer-events-none"
       style="background-image: radial-gradient(circle, #1a3a5c 1.5px, transparent 1.5px); background-size: 28px 28px;"></div>

  <div class="relative max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <div>
        <p class="text-brand-gold font-semibold uppercase tracking-widest text-xs mb-3">Qui sommes-nous</p>
        <h2 class="font-display text-3xl md:text-4xl text-brand-blue font-bold mb-5 leading-tight">
          Une association qui crée<br/>des <span class="italic text-brand-terra">passerelles</span> entre les cultures
        </h2>
        <p class="text-gray-600 leading-relaxed mb-4 text-sm sm:text-base">{texte_1}</p>
        <p class="text-gray-600 leading-relaxed mb-8 text-sm sm:text-base">{texte_2}</p>

        <div class="grid grid-cols-3 gap-3 sm:gap-4">
          {[
            { icon: '🌍', label: 'Tous niveaux',    sub: "Du débutant à l'avancé" },
            { icon: '🤝', label: '+20 bénévoles',   sub: 'Passionnés et expérimentés' },
            { icon: '📅', label: "Toute l'année",   sub: 'De sept. à juillet' },
          ].map(({ icon, label, sub }) => (
            <div class="text-center bg-white rounded-2xl p-3 sm:p-4 border border-stone-100">
              <div class="text-2xl sm:text-3xl mb-1.5">{icon}</div>
              <p class="font-semibold text-brand-blue text-xs sm:text-sm leading-snug">{label}</p>
              <p class="text-gray-400 text-[10px] sm:text-xs mt-0.5 leading-snug">{sub}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -top-6 -left-6 w-32 h-32 rounded-full bg-brand-amber/10 blur-2xl pointer-events-none"></div>
        <blockquote class="bg-brand-blue text-white rounded-3xl p-7 sm:p-10 relative overflow-hidden">
          <span class="absolute top-2 right-5 font-display text-[7rem] sm:text-[8rem] leading-none text-white/5 select-none pointer-events-none">"</span>
          <p class="font-display text-lg sm:text-2xl italic leading-relaxed mb-5 relative">{citation}</p>
          <footer class="flex items-center gap-3">
            <div class="w-8 sm:w-10 h-px bg-brand-amber flex-shrink-0"></div>
            <p class="text-brand-amber text-xs sm:text-sm font-medium">{citation_auteur}</p>
          </footer>
        </blockquote>
      </div>

    </div>
  </div>
</section>
