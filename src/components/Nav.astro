---
---
<header id="nav" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <nav class="max-w-6xl mx-auto px-5 py-3 flex items-center justify-between">

    <a href="#" class="flex items-center gap-2.5 group shrink-0">
      <img src="/images/logo.png" alt="Logo Passerelles"
           class="w-9 h-9 object-contain brightness-0 invert group-hover:brightness-[0.85] group-hover:sepia group-hover:saturate-[3] transition-all duration-300"/>
      <span class="font-display font-bold text-white text-base sm:text-lg tracking-wide group-hover:text-brand-amber transition-colors">
        Passerelles
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-0.5">
      {[
        ['#association', "L'association"],
        ['#cours',       'Cours'],
        ['#monde',       'Apprenants'],
        ['#horaires',    'Horaires'],
        ['#presse',      'Presse'],
      ].map(([href, label]) => (
        <a href={href}
           class="nav-link text-xs sm:text-sm text-white/75 hover:text-white px-2.5 sm:px-3 py-1.5 rounded-full hover:bg-white/10 transition-all">
          {label}
        </a>
      ))}
      <a href="#contact"
         class="text-xs sm:text-sm bg-brand-amber text-brand-navy font-semibold px-4 py-1.5 rounded-full hover:bg-yellow-400 active:scale-95 transition-all ml-2 shadow-sm">
        Contact
      </a>
    </div>

    <!-- Mobile burger -->
    <button id="mobile-menu-btn" class="md:hidden text-white p-1.5 rounded-lg hover:bg-white/10 transition-colors" aria-label="Menu">
      <svg id="icon-menu"  class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-brand-navy/98 backdrop-blur-md border-t border-white/10 px-4 pb-5 pt-2 flex flex-col">
    {[
      ['#association', "L'association"],
      ['#cours',       'Cours'],
      ['#monde',       'Nos apprenants'],
      ['#horaires',    'Horaires'],
      ['#presse',      'Presse'],
    ].map(([href, label]) => (
      <a href={href} class="ml text-white/80 text-sm py-3 px-3 rounded-xl hover:bg-white/10 border-b border-white/5 last:border-0 transition-colors">
        {label}
      </a>
    ))}
    <a href="#contact" class="ml mt-3 text-center bg-brand-amber text-brand-navy font-semibold text-sm py-3 px-3 rounded-xl hover:bg-yellow-400 transition-colors">
      Nous contacter
    </a>
  </div>
</header>

<script>
  const nav    = document.getElementById('nav')!;
  const btn    = document.getElementById('mobile-menu-btn')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iMenu  = document.getElementById('icon-menu')!;
  const iClose = document.getElementById('icon-close')!;

  const updateNav = () => {
    nav.classList.toggle('bg-brand-navy/95', window.scrollY > 50);
    nav.classList.toggle('backdrop-blur-md', window.scrollY > 50);
    nav.classList.toggle('shadow-xl',        window.scrollY > 50);
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  btn.addEventListener('click', () => {
    const closing = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iMenu.classList.toggle('hidden', !closing);
    iClose.classList.toggle('hidden', closing);
  });

  document.querySelectorAll('.ml').forEach(l =>
    l.addEventListener('click', () => {
      menu.classList.add('hidden');
      iMenu.classList.remove('hidden');
      iClose.classList.add('hidden');
    })
  );

  // Active section highlight
  const links = document.querySelectorAll<HTMLElement>('.nav-link');
  const sections = [...links].map(l => document.querySelector(l.getAttribute('href')!)).filter(Boolean) as Element[];
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('text-white', 'bg-white/15'));
        const active = [...links].find(l => l.getAttribute('href') === '#' + e.target.id);
        active?.classList.add('text-white', 'bg-white/15');
      }
    });
  }, { threshold: 0.4 });
  sections.forEach(s => io.observe(s));
</script>
