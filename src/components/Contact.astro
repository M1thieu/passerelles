---
// Marie-Pierre n'est plus au comité — retirée
const contacts = [
  { name: 'Freddy Loewenguth', role: 'Président',  phone: '07 66 03 14 38', tel: '+33766031438' },
  { name: 'Dominique',         role: 'Bénévole',   phone: '06 07 81 23 43', tel: '+33607812343' },
];
---
<section id="contact" class="py-24 px-6 bg-stone-50 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
       style="background-image: radial-gradient(circle, #1a3a5c 1.5px, transparent 1.5px); background-size: 28px 28px;">
  </div>

  <div class="relative max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-brand-gold font-semibold uppercase tracking-widest text-xs mb-3">Renseignements</p>
      <h2 class="font-display text-3xl md:text-4xl text-brand-blue font-bold">Nous contacter</h2>
      <p class="mt-3 text-gray-500 text-sm max-w-md mx-auto leading-relaxed">
        Passez directement sur place pendant les cours, ou appelez l'un de nos bénévoles.
      </p>
    </div>

    <!-- Contacts -->
    <div class="grid sm:grid-cols-2 gap-5 max-w-xl mx-auto mb-10">
      {contacts.map((c) => (
        <a
          href={`tel:${c.tel}`}
          class="group flex items-center gap-4 bg-white rounded-2xl p-5 shadow-sm border border-stone-200 hover:border-brand-amber hover:shadow-md active:scale-[0.98] transition-all"
        >
          <div class="w-12 h-12 shrink-0 rounded-xl bg-brand-blue/5 flex items-center justify-center group-hover:bg-brand-amber/20 transition-colors">
            <svg class="w-5 h-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-brand-blue text-sm">{c.name}</p>
            <p class="text-gray-400 text-xs">{c.role}</p>
            <p class="text-gray-600 text-sm mt-1 font-medium">{c.phone}</p>
          </div>
          <span class="ml-auto text-brand-amber text-lg">→</span>
        </a>
      ))}
    </div>

    <!-- Bloc "venez directement" -->
    <div class="bg-brand-blue text-white rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-center gap-6 md:gap-10">
      <div class="text-5xl shrink-0">🚶</div>
      <div class="text-center md:text-left">
        <p class="font-display text-xl font-bold mb-2">Pas besoin de s'inscrire à l'avance</p>
        <p class="text-blue-200 text-sm leading-relaxed">
          Venez directement sur place le <span class="text-white font-semibold">mardi matin</span> ou le
          <span class="text-white font-semibold">jeudi après-midi</span> au Foyer protestant —
          les portes sont ouvertes à toutes et à tous.
        </p>
      </div>
      <a
        href="#horaires"
        class="shrink-0 md:ml-auto inline-block bg-brand-amber text-brand-navy font-semibold text-sm px-6 py-3 rounded-full hover:bg-yellow-400 transition-colors whitespace-nowrap"
      >
        Voir le lieu →
      </a>
    </div>
  </div>
</section>
