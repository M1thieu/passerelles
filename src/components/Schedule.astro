---
const dest = encodeURIComponent('2 rue des Vosges, 68600 Neuf-Brisach, France');
const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${dest}`;
---
<section id="horaires" class="py-16 sm:py-24 px-5 sm:px-8 bg-brand-warm">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-10 sm:mb-12">
      <p class="text-brand-gold font-semibold uppercase tracking-widest text-xs mb-2">Programme</p>
      <h2 class="font-display text-3xl md:text-4xl text-brand-blue font-bold">Horaires & lieu</h2>
      <p class="mt-2 text-gray-500 text-sm">Année 2025–2026 · Reprise le mardi 2 septembre 2025</p>
    </div>

    <!-- Horaires -->
    <div class="grid sm:grid-cols-2 gap-4 sm:gap-5 mb-6 sm:mb-8">
      {[
        { emoji: '🌅', label: 'Mardi matin',      time: '10h – 12h' },
        { emoji: '☀️', label: 'Jeudi après-midi', time: '14h – 18h' },
      ].map(({ emoji, label, time }) => (
        <div class="bg-white rounded-2xl flex items-center gap-4 sm:gap-5 px-5 sm:px-6 py-4 sm:py-5 shadow-sm border border-stone-200 hover:border-brand-gold hover:shadow-md transition-all">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-brand-blue flex items-center justify-center shrink-0 text-xl sm:text-2xl shadow-sm">
            {emoji}
          </div>
          <div>
            <p class="text-[10px] sm:text-xs font-semibold uppercase tracking-widest text-gray-400 mb-0.5">{label}</p>
            <p class="text-xl sm:text-2xl font-display font-bold text-brand-blue">{time}</p>
            <p class="text-gray-400 text-xs mt-0.5">Chaque semaine · sept. → juil.</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Map -->
    <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-stone-200">
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
         class="group relative block w-full overflow-hidden"
         style="padding-top: 38%;"
         aria-label="Ouvrir l'itinéraire dans Google Maps">
        <iframe
          class="absolute inset-0 w-full h-full pointer-events-none"
          src="https://www.openstreetmap.org/export/embed.html?bbox=7.521,48.014,7.533,48.022&layer=mapnik&marker=48.018,7.527"
          style="border:0;" loading="lazy"
          title="Carte Foyer protestant Neuf-Brisach">
        </iframe>
        <div class="absolute inset-0 bg-brand-blue/0 group-hover:bg-brand-blue/15 transition-colors duration-300 flex items-center justify-center">
          <span class="opacity-0 group-hover:opacity-100 transition-all duration-300 scale-95 group-hover:scale-100 bg-white text-brand-blue font-semibold text-sm px-5 py-2.5 rounded-full shadow-lg flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Ouvrir dans Maps
          </span>
        </div>
      </a>

      <div class="px-5 sm:px-6 py-4 sm:py-5 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex items-start gap-3 flex-1">
          <span class="text-xl mt-0.5 shrink-0">📍</span>
          <div>
            <p class="font-semibold text-brand-blue">Foyer protestant</p>
            <p class="text-gray-600 text-sm">2 rue des Vosges, 68600 Neuf-Brisach</p>
            <p class="text-gray-400 text-xs mt-0.5">À côté du temple protestant</p>
          </div>
        </div>
        <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
           class="shrink-0 inline-flex items-center justify-center gap-2 bg-brand-blue text-white font-semibold text-sm px-5 py-3 rounded-full hover:bg-brand-navy active:scale-95 transition-all shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          M'y emmener
        </a>
      </div>
    </div>

  </div>
</section>
