---
---
<section class="relative min-h-screen flex flex-col justify-end overflow-hidden">

  <!-- Photo groupe plein écran -->
  <div class="absolute inset-0">
    <img
      src="/images/groupe.jpg"
      alt="Bénévoles et apprenants de l'association Passerelles"
      class="w-full h-full object-cover object-center"
    />
    <!-- dégradé : sombre en haut pour la nav, très sombre en bas pour le texte -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/70 via-brand-navy/20 to-brand-navy/90"></div>
  </div>

  <!-- Contenu texte en bas -->
  <div class="relative max-w-6xl mx-auto w-full px-6 pb-16 pt-32">
    <div class="max-w-2xl">

      <!-- Logo + nom -->
      <div class="flex items-center gap-4 mb-6 fade-up">
        <img
          src="/images/logo.png"
          alt="Logo Passerelles"
          class="w-16 h-16 object-contain brightness-0 invert drop-shadow-lg"
        />
        <div>
          <p class="text-brand-amber text-xs font-semibold uppercase tracking-[0.2em]">Association</p>
          <h1 class="font-display text-4xl sm:text-5xl text-white font-bold leading-none tracking-wide">
            Passerelles
          </h1>
        </div>
      </div>

      <p class="text-xl sm:text-2xl text-white font-display italic mb-3 fade-up delay-1">
        Des cours de français <span class="text-brand-amber not-italic font-bold">gratuits</span>,<br/>
        ouverts à tous, depuis 1988.
      </p>

      <p class="text-white/75 text-sm leading-relaxed mb-8 max-w-lg">
        Bénévoles et apprenants venus des quatre coins du monde se retrouvent
        chaque semaine en Alsace du Sud pour apprendre, échanger et créer des liens.
      </p>

      <!-- Stats en ligne -->
      <div class="flex flex-wrap gap-x-8 gap-y-3 mb-10">
        {[
          ['1988', 'Fondée en'],
          ['+20', 'Bénévoles'],
          ['100%', 'Gratuit'],
          ['+100h', 'Par an'],
        ].map(([val, label]) => (
          <div>
            <p class="text-brand-amber font-display font-bold text-2xl leading-none">{val}</p>
            <p class="text-white/60 text-xs mt-0.5">{label}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-3 fade-up delay-3">
        <a href="#horaires" class="inline-flex items-center gap-2 bg-brand-amber text-brand-navy font-semibold text-sm px-6 py-3 rounded-full hover:bg-yellow-400 active:scale-95 transition-all shadow-lg">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Voir les horaires
        </a>
        <a href="#contact" class="inline-flex items-center gap-2 border border-white/40 text-white font-semibold text-sm px-6 py-3 rounded-full hover:bg-white/10 active:scale-95 transition-all">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Nous contacter
        </a>
      </div>
    </div>
  </div>

  <!-- Vague de transition -->
  <div class="relative">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full block" style="margin-bottom:-2px">
      <path d="M0,30 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="#fafaf9"/>
    </svg>
  </div>
</section>
