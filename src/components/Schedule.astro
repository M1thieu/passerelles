---
const dest = encodeURIComponent('2 rue des Vosges, 68600 Neuf-Brisach, France');
const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${dest}`;
---
<section id="horaires" class="py-20 px-6 bg-brand-warm">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-brand-gold font-semibold uppercase tracking-widest text-sm mb-2">Programme</p>
      <h2 class="font-display text-3xl md:text-4xl text-brand-blue font-bold">Horaires & lieu</h2>
      <p class="mt-3 text-gray-600">Année 2025–2026 · Reprise le mardi 2 septembre 2025</p>
    </div>

    <!-- Horaires -->
    <div class="grid sm:grid-cols-2 gap-5 mb-10">
      <div class="bg-white rounded-2xl flex items-center gap-5 px-6 py-5 shadow-sm border border-brand-warm">
        <div class="w-14 h-14 rounded-xl bg-brand-blue flex items-center justify-center shrink-0 text-2xl">🌅</div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-0.5">Mardi matin</p>
          <p class="text-2xl font-display font-bold text-brand-blue">10h – 12h</p>
          <p class="text-gray-400 text-xs mt-0.5">Chaque mardi · sept. → juil.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl flex items-center gap-5 px-6 py-5 shadow-sm border border-brand-warm">
        <div class="w-14 h-14 rounded-xl bg-brand-blue flex items-center justify-center shrink-0 text-2xl">☀️</div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-0.5">Jeudi après-midi</p>
          <p class="text-2xl font-display font-bold text-brand-blue">14h – 18h</p>
          <p class="text-gray-400 text-xs mt-0.5">Chaque jeudi · sept. → juil.</p>
        </div>
      </div>
    </div>

    <!-- Map cliquable + adresse -->
    <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-brand-warm">

      <!-- Map = lien direct vers Maps, iframe juste décoratif/orientatif -->
      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative block w-full overflow-hidden"
        style="padding-top: 42%;"
        aria-label="Ouvrir l'itinéraire dans Google Maps"
      >
        <iframe
          class="absolute inset-0 w-full h-full pointer-events-none"
          src="https://www.openstreetmap.org/export/embed.html?bbox=7.521,48.014,7.533,48.022&layer=mapnik&marker=48.018,7.527"
          style="border:0;"
          loading="lazy"
          title="Carte Foyer protestant Neuf-Brisach"
        ></iframe>

        <!-- overlay au hover -->
        <div class="absolute inset-0 bg-brand-blue/0 group-hover:bg-brand-blue/20 transition-colors flex items-center justify-center">
          <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-white text-brand-blue font-semibold text-sm px-4 py-2 rounded-full shadow-lg flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Ouvrir dans Maps
          </span>
        </div>
      </a>

      <!-- Adresse + CTA -->
      <div class="px-6 py-5 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex items-start gap-3 flex-1">
          <span class="text-xl mt-0.5">📍</span>
          <div>
            <p class="font-semibold text-brand-blue">Foyer protestant</p>
            <p class="text-gray-600 text-sm">2 rue des Vosges, 68600 Neuf-Brisach</p>
            <p class="text-gray-400 text-xs mt-0.5">À côté du temple protestant</p>
          </div>
        </div>

        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center justify-center gap-2 bg-brand-blue text-white font-semibold text-sm px-5 py-3 rounded-full hover:bg-blue-900 active:scale-95 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          M'y emmener
        </a>
      </div>
    </div>
  </div>
</section>
