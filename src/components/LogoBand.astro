---
---
<div class="bg-stone-50 py-12 px-6 flex flex-col items-center gap-5 border-b border-stone-100 relative overflow-hidden">
  <!-- fines lignes décoratives -->
  <div class="absolute inset-0 opacity-[0.025] pointer-events-none"
       style="background-image: radial-gradient(circle, #1a3a5c 1.5px, transparent 1.5px); background-size: 28px 28px;">
  </div>

  <div class="relative flex flex-col items-center gap-4">
    <img
      src="/images/logo.png"
      alt="Association Passerelles"
      class="w-28 h-28 object-contain drop-shadow-lg hover:scale-105 transition-transform duration-300"
    />
    <div class="text-center">
      <p class="font-display text-3xl md:text-4xl font-bold text-brand-blue tracking-widest">PASSERELLES</p>
      <p class="text-brand-gold text-xs font-semibold uppercase tracking-[0.25em] mt-2">
        Cours de français gratuits · Alsace · depuis 1988
      </p>
    </div>
    <div class="flex items-center gap-3">
      <div class="w-16 h-px bg-brand-gold/30"></div>
      <span class="text-brand-gold text-xl">🌍</span>
      <div class="w-16 h-px bg-brand-gold/30"></div>
    </div>
  </div>
</div>
