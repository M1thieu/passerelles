---
<!-- Bande logo centrée : pont visuel entre le hero photo et le contenu -->
<div class="bg-stone-50 py-10 px-6 flex flex-col items-center gap-4 border-b border-stone-100">
  <img
    src="/images/logo.png"
    alt="Association Passerelles"
    class="w-24 h-24 object-contain drop-shadow-md"
  />
  <div class="text-center">
    <p class="font-display text-2xl md:text-3xl font-bold text-brand-blue tracking-wide">PASSERELLES</p>
    <p class="text-brand-gold text-xs font-semibold uppercase tracking-[0.2em] mt-1">
      Cours de français gratuits · Neuf-Brisach · depuis 1988
    </p>
  </div>
  <!-- Séparateur décoratif -->
  <div class="flex items-center gap-3 mt-1">
    <div class="w-12 h-px bg-brand-gold/40"></div>
    <span class="text-brand-gold text-lg">🌍</span>
    <div class="w-12 h-px bg-brand-gold/40"></div>
  </div>
</div>
