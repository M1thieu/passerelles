---
---
<footer class="bg-brand-navy text-white py-14 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6 items-start">

    <!-- Logo + nom -->
    <div class="flex items-center gap-4">
      <img src="/images/logo.png" alt="Logo Passerelles" class="w-14 h-14 object-contain brightness-0 invert opacity-80"/>
      <div>
        <p class="font-display font-bold text-xl text-white">Passerelles</p>
        <p class="text-white/40 text-xs mt-0.5">Association loi 1901 · Fondée en 1988</p>
        <p class="text-white/30 text-xs mt-0.5">Alsace du Sud</p>
      </div>
    </div>

    <!-- Adresse -->
    <div class="text-sm text-white/50 md:text-center">
      <p class="text-white/70 font-medium mb-1">Nous retrouver</p>
      <p>2 rue des Vosges · 68600 Neuf-Brisach</p>
      <p class="mt-0.5">Foyer protestant (à côté du temple)</p>
      <a
        href="https://www.google.com/maps/dir/?api=1&destination=2+rue+des+Vosges+68600+Neuf-Brisach"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-2 text-brand-amber text-xs hover:underline"
      >
        Ouvrir dans Maps →
      </a>
    </div>

    <!-- Horaires -->
    <div class="text-sm text-white/50 md:text-right">
      <p class="text-white/70 font-medium mb-1">Horaires</p>
      <p>Mardi · 10h – 12h</p>
      <p>Jeudi · 14h – 18h</p>
      <p class="mt-2 text-white/30 text-xs">Septembre → Juillet · Entrée libre</p>
    </div>

  </div>

  <div class="max-w-6xl mx-auto mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-white/25 text-xs">
    <span>© {new Date().getFullYear()} Association Passerelles</span>
    <span>Cours gratuits · Ouverts à toutes et tous · Partagez autour de vous 🌍</span>
  </div>
</footer>
