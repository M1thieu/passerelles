---
const origines = [
  { flag: '🇦🇫', pays: 'Afghanistan' },
  { flag: '🇺🇦', pays: 'Ukraine' },
  { flag: '🇲🇦', pays: 'Maroc' },
  { flag: '🇩🇿', pays: 'Algérie' },
  { flag: '🇷🇺', pays: 'Russie' },
  { flag: '🇸🇴', pays: 'Somalie' },
  { flag: '🇱🇰', pays: 'Sri Lanka' },
  { flag: '🇧🇯', pays: 'Bénin' },
  { flag: '🇨🇮', pays: "Côte d'Ivoire" },
  { flag: '🇵🇹', pays: 'Portugal' },
  { flag: '🇬🇪', pays: 'Géorgie' },
  { flag: '🇽🇰', pays: 'Kosovo' },
  { flag: '🇦🇲', pays: 'Arménie' },
  { flag: '🇹🇳', pays: 'Tunisie' },
  { flag: '🇹🇷', pays: 'Turquie' },
  { flag: '🇸🇾', pays: 'Syrie' },
];
---
<section id="monde" class="py-24 px-6 bg-brand-blue relative overflow-hidden">

  <!-- Décor SVG globe stylisé en arrière-plan -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.04]">
    <svg viewBox="0 0 400 400" class="w-[600px] h-[600px]" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="200" cy="200" r="190" stroke="white" stroke-width="2"/>
      <ellipse cx="200" cy="200" rx="100" ry="190" stroke="white" stroke-width="2"/>
      <ellipse cx="200" cy="200" rx="50" ry="190" stroke="white" stroke-width="2"/>
      <line x1="10" y1="200" x2="390" y2="200" stroke="white" stroke-width="2"/>
      <line x1="200" y1="10" x2="200" y2="390" stroke="white" stroke-width="2"/>
      <ellipse cx="200" cy="200" rx="190" ry="70" stroke="white" stroke-width="2"/>
      <ellipse cx="200" cy="200" rx="190" ry="130" stroke="white" stroke-width="2"/>
    </svg>
  </div>

  <div class="relative max-w-6xl mx-auto text-center">
    <p class="text-brand-amber font-semibold uppercase tracking-widest text-xs mb-3">Diversité</p>
    <h2 class="font-display text-3xl md:text-4xl text-white font-bold mb-4">
      Nos apprenants viennent du monde entier
    </h2>
    <p class="text-white/60 text-sm max-w-lg mx-auto mb-12 leading-relaxed">
      Chaque semaine, des hommes et des femmes de toutes origines se retrouvent
      autour d'une langue commune — le français — et d'une envie de s'intégrer.
    </p>

    <!-- Grille de drapeaux -->
    <div class="flex flex-wrap justify-center gap-3 mb-14">
      {origines.map(({ flag, pays }) => (
        <div class="flex items-center gap-2 bg-white/10 hover:bg-white/20 transition-colors rounded-full px-4 py-2 backdrop-blur-sm border border-white/10">
          <span class="text-xl leading-none">{flag}</span>
          <span class="text-white/80 text-xs font-medium">{pays}</span>
        </div>
      ))}
      <div class="flex items-center gap-2 bg-brand-amber/20 rounded-full px-4 py-2 border border-brand-amber/30">
        <span class="text-brand-amber text-xs font-semibold">et bien d'autres…</span>
      </div>
    </div>

    <!-- Phrase pont -->
    <div class="inline-flex items-center gap-4 text-white/50 text-sm">
      <div class="w-16 h-px bg-white/20"></div>
      <span>Une passerelle entre les cultures, une porte vers l'avenir</span>
      <div class="w-16 h-px bg-white/20"></div>
    </div>
  </div>
</section>
